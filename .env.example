# Copy to .env and fill in. .env is gitignored.

# --- Hugging Face (for downloading detection/segmentation models) ---
HF_TOKEN=
HF_HOME=~/.cache/huggingface

# --- Storage ---
DATA_DIR=./data
MODELS_DIR=./models
RESULTS_DIR=./results

# --- Compute / inference targets ---
DEVICE=cuda           # cuda | cpu | mps
TRT_LOGDIR=./logs/trt
ONNX_OPT_LEVEL=3

# --- Tracking ---
WANDB_API_KEY=
MLFLOW_TRACKING_URI=./mlruns

# --- Power profiling (optional) ---
NVML_INTERVAL_MS=100

# --- Reproducibility ---
PYTHONHASHSEED=0
